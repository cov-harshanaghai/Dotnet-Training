@model Product

@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container mt-4">
    <div class="alert alert-success">
        <h4 class="alert-heading">Order Placed!</h4>
        <p>Your order for <strong>@Model.ProductName</strong> has been placed successfully.</p>
        <hr />
        <p class="mb-0">Total Amount: @Model.Price.ToString("C")</p>
    </div>

    <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
        Continue Shopping
    </a>
</div>
