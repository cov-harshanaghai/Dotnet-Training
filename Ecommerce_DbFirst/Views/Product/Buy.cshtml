@{
    ViewBag.Title = "Order Confirmed";
    Layout = "~/Views/Shared/_Layout.cshtml"; // remove if you don't use layout
}

<div style="max-width:600px;margin:50px auto;text-align:center;font-family:Arial;">

    <div style="font-size:60px;color:green;">
        ✔
    </div>

    <h1 style="color:#2c3e50;">Order Confirmed</h1>

    <p style="font-size:18px;color:#555;">
        Thank you! Your order has been placed successfully.
    </p>

    @if (ViewBag.OrderId != null)
    {
        <p style="font-size:16px;">
            Order ID: <strong>@ViewBag.OrderId</strong>
        </p>
    }

    <p style="color:#777;">
        You will receive a confirmation email shortly.
    </p>

    <a href="@Url.Action("Index", "Home")"
       style="display:inline-block;margin-top:20px;padding:10px 20px;
        background:#27ae60;color:white;text-decoration:none;border-radius:5px;">
        Continue Shopping
    </a>

</div>