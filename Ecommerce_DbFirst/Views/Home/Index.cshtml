@{
    ViewData["Title"] = "Home";
}

<section class="bg-dark text-light text-center py-5 mt-5">
    <div class="container">
        <h1 class="fw-bold">Welcome to Brand</h1>
        <p class="lead mt-3">
            Browse our collection of quality products.
        </p>

        <a asp-controller="Product"
           asp-action="Index"
           class="btn btn-primary btn-lg mt-3">
            Browse Products
        </a>
    </div>
</section>

<section class="py-5 bg-light text-center">
    <div class="container">
        <h2 class="fw-bold">What we offer</h2>
        <p class="text-muted">
            High quality products, best prices, and fast delivery.
        </p>
    </div>
</section>