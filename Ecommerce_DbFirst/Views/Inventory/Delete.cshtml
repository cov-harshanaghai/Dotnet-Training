@model Inventory

<h2>Delete Inventory Record?</h2>

<dl class="row">
    <dt class="col-sm-3">Product Id</dt>
    <dd class="col-sm-9">@Model.ProductId</dd>
    <dt class="col-sm-3">Quantity In Stock</dt>
    <dd class="col-sm-9">@Model.QuantityInStock</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="inventoryId" value="@Model.InventoryId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>