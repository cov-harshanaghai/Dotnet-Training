@model Ecommerce_DBFirst.Dtos.RegisterDto


<form asp-action="Register" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-flex align-items-center mb-4 shadow-sm" role="alert" style="border-radius: 8px;">
        <div class="me-2">
            <!-- A simple, clean warning icon (SVG) -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
        </div>
        <div style="font-size: 0.95rem; font-weight: 500;">
            <!-- The framework injects the <ul> list of errors directly right here -->
        </div>
    </div>
    <label asp-for="Email"></label>
    <input type="text" class="form-control" asp-for="Email" />

    <label asp-for="Password"></label>
    <input asp-for="Password" class="form-control" type="password" />

    <label asp-for="ConfirmPassword"></label>
    <input asp-for="ConfirmPassword" class="form-control" type="password" />

    <div class="text-center"><button type="submit" class="btn btn-info mt-3">Register</button></div>
    

</form>

